// nextflow.config - Minimal configuration for MD Factory Pipeline
// Simple version with just the essentials


// Generate useful reports
report {
    enabled = true
    file = "nextflow-report.html"
}

timeline {
    enabled = true
    file = "nextflow-timeline.html"
}

dag {
    enabled = true
    file = "nextflow-dag.html"
}

trace {
    enabled = true
    file = "nextflow-trace.txt"
}

// SLURM configuration for GROMACS pipeline
process {
    executor = 'slurm'
    queue = 'stdg_int'
    echo = true    
    // Load required modules
    beforeScript = 'module load gromacs-gpu'
    clusterOptions = '--gres=gpu:1'    
    // Resource settings for all processes
    cpus = 12 
    time = '1h'
    memory = '4GB'
}

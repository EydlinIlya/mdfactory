// nextflow.config - Minimal configuration for MD Factory Pipeline
// Simple version with just the essentials

// Show process output in terminal (so you can see echo commands)
process {
    echo = true

    // Retry failed processes once
    errorStrategy = 'retry'
    maxRetries = 1
}

// Generate useful reports
report {
    enabled = true
    file = "nextflow-report.html"
}

timeline {
    enabled = true
    file = "nextflow-timeline.html"
}

dag {
    enabled = true
    file = "nextflow-dag.html"
}

trace {
    enabled = true
    file = "nextflow-trace.txt"
}

// Pipeline defaults
params {
    csv_file = null
    output_dir = './results'
}

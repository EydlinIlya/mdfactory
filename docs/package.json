{
  "name": "mdfactory-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "bun run docs:generate && bun --bun next build",
    "dev": "bun run docs:generate && next dev",
    "start": "next start",
    "types:check": "fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "docs:generate": "bun ./scripts/generate-docs.mjs"
  },
  "dependencies": {
    "@orama/orama": "^3.1.16",
    "fumadocs-core": "^16.6.17",
    "fumadocs-mdx": "^14.2.10",
    "fumadocs-python": "^0.0.6",
    "fumadocs-ui": "^16.6.17",
    "lucide-react": "^0.552.0",
    "mermaid": "^11.12.1",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^6.1.0",
    "shiki": "^3.15.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3"
  }
}
